# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Database Configuration
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db:5432/db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_NAME=db_name
DB_HOST=db
DB_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=False

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_WORKERS=2
DEBUG=True
LOG_LEVEL=INFO

# N8N Configuration
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_123
N8N_HOST=n8n
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_TUNNEL_URL=http://localhost:5678
WEBHOOK_URL=your_public_webhook_url_here

# Qdrant Configuration
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_PROTOCOL=http
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5
EMBEDDING_BATCH_SIZE=64
VECTOR_COLLECTION_NAME=feedback_embeddings

# Gemini Configuration
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=1024
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40

# Dataset Configuration
DATASET_NAME=jakartaresearch/google-play-review
DATASET_SPLIT=train
DATASET_CACHE_DIR=./data/cache
SAMPLE_SIZE=500

# Tableau Configuration
TABLEAU_SERVER=localhost
TABLEAU_PORT=8000
TABLEAU_USERNAME=admin
TABLEAU_PASSWORD=password
TABLEAU_SITE_ID=default

# Feature Flags
ENABLE_RAG=True
ENABLE_SENTIMENT_ANALYSIS=True

# Cache Configuration
REDIS_URL=redis://redis:6379
CACHE_TTL=3600